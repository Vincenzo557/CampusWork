              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Student\",\n  \"email\": \"teststudent@ug.edu.gh\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\",\n  \"role\": \"student\",\n  \"student_id\": \"UG/2024/999\",\n  \"faculty\": \"Engineering\",\n  \"course\": \"Computer Science\",\n  \"year_of_study\": 2\n}"
